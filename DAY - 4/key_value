package day4;
import java.util.Scanner;
public class keyvalue {
    public static void main(String[] args) {
        Scanner sr = new Scanner(System.in);
        int num= sr.nextInt();
        int key=sr.nextInt();
        int count=0;
        while (num != 0) {
            int pop = num % 10;
            if (pop == key){
                count++;
            }
            num=num/10;
        }
        System.out.println(count);
    }
}
